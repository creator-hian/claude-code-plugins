{
  "description": "Reinforce user prompts by re-injecting them as system context",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/reinforce-prompt.js\""
          }
        ]
      }
    ]
  }
}
